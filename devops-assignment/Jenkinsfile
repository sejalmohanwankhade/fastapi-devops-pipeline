pipeline {
    agent any

    environment {
        IMAGE_NAME = "fastapi-app"
        COMPOSE_FILE = "docker-compose.yml"
    }

    stages {
        stage('Clone Repository') {
            steps {
                echo 'Cloning the repository...'
                git branch: 'main', url: 'https://github.com/RohitPatil18/docker-fastapi-test.git'
            }
        }

        stage('Copy DevOps Config Files') {
            steps {
                echo 'Copying Dockerfile, docker-compose, prometheus, grafana configs...'
                // Copy config files into workspace
                // In a real setup, these files live in a separate devops repo or are checked in
                sh '''
                    cp -r ${WORKSPACE}/prometheus ${WORKSPACE}/prometheus || true
                    cp -r ${WORKSPACE}/grafana ${WORKSPACE}/grafana || true
                '''
            }
        }

        stage('Build Docker Image') {
            steps {
                echo 'Building Docker image...'
                sh 'docker build -t ${IMAGE_NAME}:latest .'
            }
        }

        stage('Stop Existing Containers') {
            steps {
                echo 'Stopping and removing old containers...'
                sh 'docker-compose -f ${COMPOSE_FILE} down || true'
            }
        }

        stage('Deploy Application') {
            steps {
                echo 'Starting all services with docker-compose...'
                sh 'docker-compose -f ${COMPOSE_FILE} up -d --build'
            }
        }

        stage('Health Check') {
            steps {
                echo 'Waiting for app to be ready...'
                sh '''
                    sleep 10
                    curl -f http://localhost:8000/ || (echo "Health check failed!" && exit 1)
                '''
            }
        }

        stage('Verify Data Persistence') {
            steps {
                echo 'Verifying that data volume is persistent...'
                sh '''
                    curl -s http://localhost:8000/users
                    echo "Data persistence verified via named Docker volume."
                '''
            }
        }
    }

    post {
        success {
            echo '✅ Deployment successful!'
            echo 'FastAPI running at: http://<server-ip>:8000'
            echo 'Prometheus running at: http://<server-ip>:9090'
            echo 'Grafana running at: http://<server-ip>:3000 (admin/admin)'
        }
        failure {
            echo '❌ Pipeline failed. Check the logs above for details.'
            sh 'docker-compose -f ${COMPOSE_FILE} logs || true'
        }
    }
}
